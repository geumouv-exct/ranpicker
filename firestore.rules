rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isCompanyGmail() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email == 'byeori0713@gmail.com';
    }
    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /workspaces/{workspaceId}/employees/{employeeId} {
      allow read: if signedIn();
      allow create, update, delete: if isCompanyGmail();
    }
    match /workspaces/{workspaceId}/projects/{projectId} {
      allow read: if signedIn();
      allow create, update, delete: if isCompanyGmail();
    }

    // 같은 계정으로 다른 기기에서 로그인했을 때 이력관리가 확실히 유지되도록 하는 사용자별 백업 경로입니다.
    match /users/{userId}/projects/{projectId} {
      allow read: if isOwner(userId) || isCompanyGmail();
      allow create, update, delete: if isOwner(userId) || isCompanyGmail();
    }

    // 이전 버전 호환용 root 컬렉션입니다.
    match /employees/{employeeId} {
      allow read: if signedIn();
      allow create, update, delete: if isCompanyGmail();
    }
    match /projects/{projectId} {
      allow read: if signedIn();
      allow create, update, delete: if isCompanyGmail();
    }
  }
}
