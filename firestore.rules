rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isCompanyGmail() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email == 'byeori0713@gmail.com';
    }

    match /workspaces/{workspaceId}/employees/{employeeId} {
      allow read: if signedIn();
      allow create, update, delete: if isCompanyGmail();
    }
    match /workspaces/{workspaceId}/projects/{projectId} {
      allow read: if signedIn();
      allow create, update, delete: if isCompanyGmail();
    }

    // 이전 버전 호환용. 기존 root 컬렉션을 쓰고 있었다면 읽기/쓰기는 유지합니다.
    match /employees/{employeeId} {
      allow read: if signedIn();
      allow create, update, delete: if isCompanyGmail();
    }
    match /projects/{projectId} {
      allow read: if signedIn();
      allow create, update, delete: if isCompanyGmail();
    }
  }
}
